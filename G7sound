body {
  margin: 0;
  font-family: Arial;
  background: #000;
  color: #fff;
}

header {
  background: #111;
  text-align: center;
  padding: 20px;
  border-bottom: 2px solid #444;
}

nav {
  text-align: center;
  padding: 10px;
  background: #000;
}

nav a {
  color: #fff;
  margin: 10px;
  text-decoration: none;
}

#banner {
  padding: 60px;
  text-align: center;
  background: linear-gradient(black, #111);
}

section {
  padding: 20px;
}

.card {
  background: #111;
  padding: 20px;
  margin: 10px 0;
  border-radius: 10px;
  border: 1px solid #222;
}

button {
  padding: 10px;
  background: #00ff88;
  border: none;
  cursor: pointer;
}

.btn {
  background: #25d366;
  padding: 10px 20px;
  text-decoration: none;
  color: white;
  border-radius: 8px;
function comprar(produto) {
  alert("Você será redirecionado para pagamento de: " + produto);

  // LINK EXEMPLO MERCADO PAGO (você vai trocar depois)
  window.open("https://mpago.la/SEULINKAQUI", "_blank");
}

function calcular() {
  let falantes = document.getElementById("falantes").value;
  let ohms = document.getElementById("impedancia").value;

  let resultado = ohms / falantes;

  document.getElementById("resultado").innerText =
    "Impedância final: " + resultado.toFixed(2) + " Ohms";
}
}
