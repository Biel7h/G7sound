<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>G7Sound</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <h1>🔊 G7Sound</h1>
  <p>Som automotivo profissional</p>
</header>

<nav>
  <a href="#produtos">Produtos</a>
  <a href="#simulador">Simulador</a>
  <a href="#projetos">Projetos</a>
  <a href="#contato">Contato</a>
</nav>

<section id="banner">
  <h2>Potência, Qualidade e Ajuste Fino 🚗💥</h2>
</section>

<section id="produtos">
  <h2>Produtos</h2>

  <div class="card">
    <h3>Subwoofer 12"</h3>
    <p>Grave forte e limpo</p>
    <button onclick="comprar('Subwoofer 12')">Comprar</button>
  </div>

  <div class="card">
    <h3>Módulo Amplificador</h3>
    <p>Alta potência</p>
    <button onclick="comprar('Módulo')">Comprar</button>
  </div>

</section>

<section id="simulador">
  <h2>Simulador de Impedância</h2>

  <input type="number" id="falantes" placeholder="Qtd de falantes">
  <input type="number" id="impedancia" placeholder="Ohms de cada">

  <button onclick="calcular()">Calcular Paralelo</button>

  <p id="resultado"></p>
</section>

<section id="projetos">
  <h2>Projetos (Antes e Depois)</h2>

  <div class="card">
    <h3>Projeto Gol G5</h3>
    <p>Antes: Som fraco</p>
    <p>Depois: Grave forte e qualidade top</p>
  </div>

</section>

<section id="contato">
  <h2>Contato</h2>
  <a class="btn" href="https://wa.me/5511979639561" target="_blank">
    Falar no WhatsApp
  </a>
</section>

<footer>
  <p>© 2026 G7Sound</p>
</footer>

<script src="script.js"></script>
</body>
